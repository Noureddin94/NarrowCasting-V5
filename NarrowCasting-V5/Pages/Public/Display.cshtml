@page "/Display/{screenId:int}"
@model NarrowCasting_V5.Pages.Public.DisplayModel
@{
    ViewData["Title"] = "Narrowcast";
    Layout = null;
}

<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(Model.Screen?.Name ?? "Narrowcast")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; background: #0a0f1e; color: #fff; font-family: 'Segoe UI', system-ui, sans-serif; overflow: hidden; }

        /* Fullscreen carousel */
        .nc-display { height: 100vh; display: flex; flex-direction: column; }
        .nc-topbar {
            background: rgba(0,0,0,.6); backdrop-filter: blur(8px);
            padding: .75rem 1.5rem;
            display: flex; justify-content: space-between; align-items: center;
            flex-shrink: 0;
        }
        .nc-topbar .screen-name { font-size: 1rem; font-weight: 700; opacity: .85; }
        .nc-topbar .clock       { font-size: 1.1rem; font-weight: 300; font-variant-numeric: tabular-nums; }
        .nc-topbar .dept-badge  { background: rgba(255,255,255,.15); border-radius: 20px;
                                   padding: .2rem .8rem; font-size: .8rem; }

        /* Content area */
        .nc-content { flex: 1; position: relative; display: flex; align-items: center; justify-content: center; }

        /* Announcement card */
        .ann-card {
            background: rgba(255,255,255,.08); backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 16px; padding: 3rem 4rem; max-width: 800px; text-align: center;
            animation: fadeInUp .6s ease;
        }
        .ann-card .ann-dept   { font-size: .85rem; opacity: .6; margin-bottom: .5rem; letter-spacing: .05em; text-transform: uppercase; }
        .ann-card .ann-title  { font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; line-height: 1.2; }
        .ann-card .ann-body   { font-size: 1.1rem; opacity: .8; line-height: 1.6; }
        

        /* Ticker / bottom bar */
        .nc-ticker {
            background: rgba(13,110,253,.85); padding: .5rem 1.5rem;
            display: flex; align-items: center; gap: 1rem; flex-shrink: 0; overflow: hidden;
        }
        .nc-ticker .ticker-label { font-weight: 700; white-space: nowrap; font-size: .85rem; }
        .nc-ticker .ticker-text  { white-space: nowrap; animation: ticker 30s linear infinite; font-size: .9rem; }

        /* Progress bar */
        .nc-progress { height: 3px; background: rgba(255,255,255,.15); flex-shrink: 0; }
        .nc-progress-bar { height: 3px; background: #0d6efd; transition: none; }
    </style>
</head>
<body>
@if (Model.Screen is null)
{
    <div class="d-flex align-items-center justify-content-center h-100 text-muted">
        <div class="text-center">
            <i class="bi bi-exclamation-triangle" style="font-size:3rem"></i>
            <p class="mt-3">Scherm niet gevonden.</p>
        </div>
    </div>
}
else
{
    <div class="nc-display">
        <!-- Top bar -->
        <div class="nc-topbar">
            <div class="d-flex align-items-center gap-3">
                <span class="screen-name"><i class="bi bi-display me-2"></i>@Model.Screen.Name</span>
                <span class="dept-badge">@Model.Screen.Department?.Name</span>
            </div>
            <div class="clock" id="clock"></div>
        </div>

        <!-- Progress -->
        <div class="nc-progress">
            <div class="nc-progress-bar" id="progressBar"></div>
        </div>

        <!-- Main content area -->
        <div class="nc-content">
            @if (Model.Announcements.Any())
            {
                <div class="ann-card" id="annCard">
                    <div class="ann-dept" id="annDept"></div>
                    <div class="ann-title" id="annTitle">Laden...</div>
                    <div class="ann-body" id="annBody"></div>
                </div>
            }
            else
            {
                <div class="text-center opacity-50">
                    <i class="bi bi-display" style="font-size:4rem"></i>
                    <p class="mt-3 fs-5">Geen content beschikbaar</p>
                </div>
            }
        </div>

        <!-- Ticker -->
        @if (Model.Announcements.Any())
        {
            <div class="nc-ticker">
                <span class="ticker-label">INFO</span>
                <span class="ticker-text">
                    @string.Join("  •  ", Model.Announcements.Select(a => a.Title))
                </span>
            </div>
        }
    </div>

    @if (Model.Announcements.Any())
    {
        <script>
            const announcements = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Announcements.Select(a => new { a.Title, a.Content, dept = a.Department?.Name ?? "" })));

            let current = 0;
            const DURATION = 8000; // 8 seconds per slide

            function showAnnouncement(index) {
                const a = announcements[index];
                const card = document.getElementById('annCard');
                card.style.animation = 'none';
                void card.offsetWidth; // reflow
                card.style.animation = 'fadeInUp .6s ease';

                document.getElementById('annDept').textContent  = a.dept;
                document.getElementById('annTitle').textContent = a.title;
                document.getElementById('annBody').textContent  = a.content;

                // Progress bar
                const bar = document.getElementById('progressBar');
                bar.style.transition = 'none';
                bar.style.width = '0%';
                void bar.offsetWidth;
                bar.style.transition = `width ${DURATION}ms linear`;
                bar.style.width = '100%';
            }

            function next() {
                current = (current + 1) % announcements.length;
                showAnnouncement(current);
            }

            showAnnouncement(0);
            setInterval(next, DURATION);

            // Clock
            function updateClock() {
                const now = new Date();
                document.getElementById('clock').textContent =
                    now.toLocaleTimeString('nl-NL', { hour: '2-digit', minute: '2-digit' });
            }
            updateClock();
            setInterval(updateClock, 1000);

            // Auto-refresh every 30 seconds (NFR-6)
            setTimeout(() => location.reload(), 30000);
        </script>
    }
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>